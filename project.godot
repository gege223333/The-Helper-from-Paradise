; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="天堂帮手"
run/main_scene="uid://drymkkick40lb"
config/features=PackedStringArray("4.4", "Forward Plus")

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
Global="*res://Global.gd"

[dialogic]

directories/dch_directory={
"佳佳": "res://dialogic/剧情/佳佳.dch",
"剧情/（嘈杂的声音）": "res://dialogic/剧情/（嘈杂的声音）.dch",
"大伟": "res://dialogic/剧情/大伟.dch",
"小明": "res://dialogic/剧情/小明.dch",
"小艾": "res://dialogic/剧情/小艾.dch",
"李老头": "res://dialogic/剧情/李老头.dch",
"王老头": "res://dialogic/剧情/王老头.dch",
"老伴": "res://dialogic/剧情/老伴.dch",
"邮递员": "res://dialogic/剧情/邮递员.dch"
}
directories/dtl_directory={
"15天的对话-小艾": "res://dialogic/timeline/15天的对话-小艾.dtl",
"20天的对话-彩票": "res://dialogic/timeline/20天的对话-彩票.dtl",
"ending": "res://dialogic/timeline/ending.dtl",
"main": "res://dialogic/timeline/main.dtl",
"儿孙自有儿孙福": "res://dialogic/timeline/儿孙自有儿孙福.dtl",
"彩票之前": "res://dialogic/timeline/彩票之前.dtl",
"彩票之后": "res://dialogic/timeline/彩票之后.dtl",
"比赛结果": "res://screan/比赛结果.dtl",
"第二关第三关剧情": "res://dialogic/timeline/第二关第三关剧情.dtl",
"能力获得提示": "res://dialogic/timeline/能力获得提示.dtl",
"赛后": "res://dialogic/剧情/赛后.dtl"
}
layout/style_directory={
"": "res://addons/dialogic/Resources/对话框样式.tres",
"对话框样式": "res://addons/dialogic/Resources/对话框样式.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://addons/dialogic/Resources/对话框样式.tres"]
layout/default_style="res://addons/dialogic/Resources/对话框样式.tres"
variables={}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.0
animations/join_default_wait=false
animations/leave_default_length=0.0
animations/leave_default_wait=false
animations/cross_fade_default_length=0.0
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[gui]

theme/custom_font="uid://bl5cmbmkuw0xp"

